{
  "version": 4,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "include": [
    "caffeine-build/cmake/presets/base.json"
  ],
  "configurePresets": [
    {
      "name": "unit-tests-gtest",
      "displayName": "SAL Unit Tests (Native GTest)",
      "inherits": "base-common",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/unit-tests-gtest",
      "cacheVariables": {
        "CFN_BUILD_TESTS": "ON"
      }
    }
  ]
}